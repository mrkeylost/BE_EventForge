<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Activate Your Account</title>
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: "DM Sans", Arial, sans-serif;
        background-color: #f0ede8;
        padding: 40px 16px;
        -webkit-font-smoothing: antialiased;
      }
      .wrapper {
        max-width: 580px;
        margin: 0 auto;
      }
      .topbar {
        text-align: center;
        margin-bottom: 24px;
      }
      .topbar-logo {
        font-family: "DM Serif Display", serif;
        font-size: 20px;
        color: #1a1a1a;
        letter-spacing: 0.04em;
      }
      .topbar-logo span {
        color: #2d6a4f;
      }
      .card {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 32px rgba(0, 0, 0, 0.07);
      }
      .hero {
        background: linear-gradient(135deg, #1b4332, #2d6a4f 55%, #40916c);
        padding: 52px 40px 44px;
        text-align: center;
        position: relative;
        overflow: hidden;
      }
      .hero::before {
        content: "";
        position: absolute;
        top: -60px;
        right: -60px;
        width: 220px;
        height: 220px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.05);
      }
      .hero::after {
        content: "";
        position: absolute;
        bottom: -80px;
        left: -40px;
        width: 180px;
        height: 180px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.04);
      }
      .hero-title {
        font-family: "DM Serif Display", serif;
        font-size: 34px;
        color: #fff;
        line-height: 1.2;
        margin-bottom: 8px;
        position: relative;
        z-index: 1;
      }
      .hero-subtitle {
        font-size: 14px;
        color: rgba(255, 255, 255, 0.72);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-weight: 500;
        position: relative;
        z-index: 1;
      }
      .body {
        padding: 40px 40px 32px;
      }
      .greeting {
        font-size: 17px;
        color: #1a1a1a;
        margin-bottom: 12px;
        font-weight: 500;
      }
      .greeting strong {
        color: #2d6a4f;
      }
      .intro-text {
        font-size: 15px;
        color: #555;
        line-height: 1.65;
        margin-bottom: 28px;
      }
      .info-card {
        background: #f8f7f4;
        border: 1px solid #e8e4de;
        border-radius: 12px;
        padding: 20px 24px;
        margin-bottom: 32px;
      }
      .info-card-label {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #999;
        margin-bottom: 16px;
      }
      .info-row {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 10px 0;
        border-bottom: 1px solid #ede9e2;
      }
      .info-row:last-child {
        border-bottom: none;
        padding-bottom: 0;
      }
      .info-row:first-of-type {
        padding-top: 0;
      }
      .info-icon {
        flex-shrink: 0;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        background: #e8f5e9;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .info-icon svg {
        width: 16px;
        height: 16px;
        stroke: #2d6a4f;
        fill: none;
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
      }
      .info-content {
        flex: 1;
        min-width: 0;
      }
      .info-key {
        font-size: 11px;
        color: #999;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 2px;
      }
      .info-value {
        font-size: 14px;
        color: #1a1a1a;
        font-weight: 500;
        word-break: break-all;
      }
      .cta-section {
        text-align: center;
        margin-bottom: 28px;
      }
      .cta-text {
        font-size: 15px;
        color: #555;
        margin-bottom: 20px;
        line-height: 1.55;
      }
      .cta-button {
        display: inline-block;
        padding: 15px 40px;
        background: linear-gradient(135deg, #1b4332, #2d6a4f);
        color: #fff !important;
        text-decoration: none;
        border-radius: 100px;
        font-size: 15px;
        font-weight: 600;
        letter-spacing: 0.03em;
        box-shadow: 0 4px 16px rgba(45, 106, 79, 0.35);
      }
      .divider {
        border: none;
        border-top: 1px solid #ede9e2;
        margin: 8px 0 24px;
      }
      .help-text {
        font-size: 13.5px;
        color: #777;
        line-height: 1.6;
        margin-bottom: 20px;
      }
      .help-text a {
        color: #2d6a4f;
        text-decoration: none;
        font-weight: 500;
      }
      .sign-off {
        font-size: 14px;
        color: #555;
        line-height: 1.6;
      }
      .sign-off strong {
        color: #1a1a1a;
        font-weight: 600;
      }
      .footer {
        padding: 20px 40px 28px;
        border-top: 1px solid #f0ede8;
        background: #fcfaf8;
      }
      .footer-text {
        font-size: 12px;
        color: #aaa;
        text-align: center;
        line-height: 1.7;
      }
      .footer-text a {
        color: #2d6a4f;
        text-decoration: none;
      }
      .bottom-note {
        text-align: center;
        margin-top: 20px;
        font-size: 12px;
        color: #bbb;
      }
      @media (max-width: 600px) {
        body {
          padding: 0;
        }
        .hero {
          padding: 40px 24px 36px;
        }
        .hero-title {
          font-size: 28px;
        }
        .body {
          padding: 28px 24px 24px;
        }
        .footer {
          padding: 16px 24px 24px;
        }
      }
    </style>
  </head>
  <body>
    <div class="wrapper">
      <div class="topbar">
        <span class="topbar-logo">EventForge<span>.</span></span>
      </div>

      <div class="card">
        <div class="hero">
          <div class="hero-title">Welcome!</div>
          <div class="hero-subtitle">One last step to get started</div>
        </div>

        <!-- Body -->
        <div class="body">
          <p class="greeting">Hello, <strong><%= username %></strong> 👋</p>
          <p class="intro-text">
            Thank you for signing up for
            <strong>EventForge</strong>. Your account has been
            successfully created. Here's a summary of your account details:
          </p>

          <div class="info-card">
            <div class="info-card-label">Account Details</div>

            <div class="info-row">
              <div class="info-icon">
                <svg viewBox="0 0 24 24">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                  <circle cx="12" cy="7" r="4" />
                </svg>
              </div>
              <div class="info-content">
                <div class="info-key">Full Name</div>
                <div class="info-value"><%= fullName %></div>
              </div>
            </div>

            <div class="info-row">
              <div class="info-icon">
                <svg viewBox="0 0 24 24">
                  <path
                    d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                  />
                  <polyline points="22,6 12,13 2,6" />
                </svg>
              </div>
              <div class="info-content">
                <div class="info-key">Email</div>
                <div class="info-value"><%= email %></div>
              </div>
            </div>

            <div class="info-row">
              <div class="info-icon">
                <svg viewBox="0 0 24 24">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                  <line x1="16" y1="2" x2="16" y2="6" />
                  <line x1="8" y1="2" x2="8" y2="6" />
                  <line x1="3" y1="10" x2="21" y2="10" />
                </svg>
              </div>
              <div class="info-content">
                <div class="info-key">Registration Date</div>
                <div class="info-value"><%= createdAt %></div>
              </div>
            </div>
          </div>

          <div class="cta-section">
            <p class="cta-text">
              Click the button below to activate your account and start using
              our service.
            </p>
            <a href="<%= activationLink %>" class="cta-button"
              >Activate My Account</a
            >
          </div>

          <hr class="divider" />

          <p class="help-text">
            If the button above doesn't work, copy and paste this URL into your
            browser:<br />
            <a href="<%= activationLink %>"><%= activationLink %></a>
          </p>
          <p class="help-text">
            If you have any questions or need help, feel free to
            <a href="mailto:support@event.com">contact our team</a>.
          </p>

          <p class="sign-off">
            Warm regards,<br />
            <strong>EventForge Team</strong>
          </p>
        </div>

        <div class="footer">
          <p class="footer-text">
            &copy; 2026 EventForge. All Rights Reserved.<br />
            If you did not register, please ignore this email.
          </p>
        </div>
      </div>

      <p class="bottom-note">
        This email was sent automatically, please do not reply.
      </p>
    </div>
  </body>
</html>
